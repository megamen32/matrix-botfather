# Matrix Homeserver URL
MATRIX_HOMESERVER_URL=https://chat.bezrabotnyi.com

# Auth mode: "mas" (Matrix Authentication Service) or "synapse" (local passwords)
AUTH_MODE=mas

# Admin token for Synapse Admin API (obtained via login)
MATRIX_ADMIN_TOKEN=your_admin_token_here

# Server name (domain part after :)
MATRIX_SERVER_NAME=chat.bezrabotnyi.com

# BotFather's own Matrix token (optional — if not set, logs in as admin)
# MATRIX_BOT_TOKEN=
# MATRIX_BOT_USER_ID=@botfather:chat.bezrabotnyi.com

# ===== MAS settings (only for AUTH_MODE=mas) =====
# Docker container name for MAS
MAS_DOCKER_CONTAINER=matrix-mas
# Path to MAS config inside container
MAS_CONFIG_PATH=/config/config.yaml

# ===== Admin login (fallback if MATRIX_BOT_TOKEN not set) =====
MATRIX_ADMIN_USER=aiadmin
MATRIX_ADMIN_PASS=your_password_here