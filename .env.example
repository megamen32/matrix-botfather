# Matrix Homeserver URL
MATRIX_HOMESERVER_URL=https://chat.bezrabotnyi.com

# ===== Вариант 1: Бот через существующий аккаунт =====
# Если BotFather работает под админ-аккаунтом напрямую
MATRIX_ADMIN_USER=aiadmin
MATRIX_ADMIN_PASS=your_password_here

# ===== Вариант 2: Отдельный бот-аккаунт (рекомендуется) =====
# Создайте бота через !bf newbot на другом инстансе, затем впишите его токен
# MATRIX_BOT_TOKEN=syt_xxxxx
# MATRIX_BOT_USER_ID=@botfather:bezrabotnyi.com

# Server name (domain part after :)
MATRIX_SERVER_NAME=bezrabotnyi.com